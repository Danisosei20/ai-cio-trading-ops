# Copy this file to .env and fill in your own values.
# .env is intentionally ignored by Git.
#
# Never store Robinhood account numbers, passwords, access tokens, cookies,
# recovery codes, or live-broker API keys here. Robinhood and Slack
# authentication must remain in their authorized connectors.

# Personal routing
TIMEZONE=America/New_York
SLACK_CHANNEL_ID=YOUR_SLACK_CHANNEL_ID
HEALTH_SLACK_CHANNEL_ID=YOUR_SEPARATE_HEALTH_CHANNEL_ID
SLACK_BOT_TOKEN=YOUR_LOCAL_SLACK_BOT_TOKEN
SLACK_USER_TOKEN=YOUR_LOCAL_SLACK_USER_TOKEN

# Approval preferences
APPROVAL_WINDOW_MINUTES=120
ROBINHOOD_ACCOUNT_NICKNAME=Agentic

# Optional context shown to the CIO. Do not put secrets in these fields.
INVESTMENT_OBJECTIVE=Long-term after-tax risk-adjusted growth with capital preservation
RISK_TOLERANCE=moderate
TAX_CONTEXT=taxable_and_retirement_accounts
PERSONAL_NOTES=

# Trading safety. Keep live trading disabled during development and validation.
# research_only | paper_auto | live_approval
TRADING_MODE=research_only
TRADING_ENABLED=false
PAPER_TRADING_ENABLED=false

# Alpaca paper only. Prefer injecting these from a local secret manager.
# If you use the ignored .env file, restrict it with: chmod 600 .env
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_TRADE=true
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
