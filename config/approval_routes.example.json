{
  "mode": "send",
  "timezone": "${TIMEZONE}",
  "approval_window_minutes": "${APPROVAL_WINDOW_MINUTES}",
  "personal_context": {
    "account_nickname": "${ROBINHOOD_ACCOUNT_NICKNAME}",
    "investment_objective": "${INVESTMENT_OBJECTIVE}",
    "risk_tolerance": "${RISK_TOLERANCE}",
    "tax_context": "${TAX_CONTEXT}"
  },
  "investment_policy": {
    "strategy_version": "v1",
    "purchase_universe": "sp500_current_constituents_only",
    "membership_max_age_hours": 24,
    "require_live_quote": true,
    "require_current_news": true,
    "minimum_independent_research_sources": 2,
    "require_volume_liquidity_analysis": true,
    "require_execution_quality_analysis": true,
    "require_trend_volatility_event_analysis": true,
    "learning_checkpoints_trading_days": [1, 5, 20],
    "minimum_observations_before_policy_change": 10,
    "automatic_profit_sales": false,
    "profitable_positions_action": "review_take_profit_then_request_codex_approval"
  },
  "risk_limits": {
    "max_order_value_usd": 25,
    "minimum_cash_reserve_usd": 50,
    "max_open_positions": 1,
    "max_daily_loss_usd": 5,
    "max_weekly_loss_usd": 10,
    "max_position_weight": 0.10,
    "max_sector_weight": 0.30,
    "minimum_cash_weight": 0.05,
    "max_daily_approved_capital_usd": 5000,
    "max_pending_approvals": 3,
    "max_bid_ask_spread_pct": 0.005,
    "max_order_pct_average_daily_volume": 0.001
  },
  "entry_controls": {
    "earnings_blackout_trading_days": 5,
    "loss_cooldown_trading_days": 5,
    "require_data_quality_score": 100,
    "risk_on_minimum_score": 90,
    "neutral_minimum_score": 93,
    "risk_off_minimum_score": 97
  },
  "runtime": {
    "database_path": "outputs/cio.db",
    "dashboard_path": "outputs/dashboard.html",
    "paper_database_path": "outputs/paper/cio.db",
    "paper_dashboard_path": "outputs/paper/dashboard.html",
    "live_database_path": "outputs/live/cio.db",
    "live_dashboard_path": "outputs/live/dashboard.html",
    "structured_logging": true,
    "broker_reconciliation_required_after_uncertain_failure": true,
    "database_schema_version": 2,
    "lifecycle_lease_seconds": 300,
    "backup_before_migration": true,
    "audit_retention_days": 2555,
    "delivery_retention_days": 365
  },
  "schedule": {
    "enabled": true,
    "time_local": "09:45",
    "timezone": "${TIMEZONE}",
    "weekdays_only": true,
    "require_official_market_calendar_open_day": true,
    "skip_message_when_market_closed": true
  },
  "slack_reply_monitor": {
    "enabled": true,
    "mode": "same_active_task_event_scoped",
    "window_minutes_after_message": 10,
    "reject_when_window_expires_without_response": true,
    "cleanup_after_terminal_state": true,
    "read_channel_and_threads": true,
    "deduplicate_by_channel_and_message_ts": true,
    "safe_test_commands": ["YES", "NO", "$amount", "quantity shares", "TEST SIZE $amount", "TEST SHARES quantity", "TEST REJECT"],
    "no_may_reject_linked_pending_approval": true,
    "yes_requests_sizing_but_never_approves": true,
    "execution_commands_from_slack": "always_block"
  },
  "channels": {
    "slack": {
      "enabled": true,
      "channel_id": "${SLACK_CHANNEL_ID}",
      "required_tools": [
        "slack._slack_send_message"
      ]
    },
    "health_slack": {
      "enabled": true,
      "channel_id": "${HEALTH_SLACK_CHANNEL_ID}"
    },
    "phone": {
      "enabled": false,
      "method": "",
      "to": ""
    }
  },
  "rules": {
    "send_no_action_summary": true,
    "send_trade_approval_requests": true,
    "never_place_without_confirmed_approval": true,
    "allowed_account_policy": "agentic_allowed_only",
    "default_trade_action": "review_only"
  }
}
